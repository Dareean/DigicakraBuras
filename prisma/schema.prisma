datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id             Int      @id @default(autoincrement())
  whatsappNumber String   @unique
  name           String   @default("")
  totalStamps    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
  stamps         Stamp[]
}

model Order {
  id          Int         @id @default(autoincrement())
  orderCode   String      @unique
  customerId  Int?
  customer    Customer?   @relation(fields: [customerId], references: [id])
  orderSource String      // "online" | "pos"
  cashierId   Int?
  cashier     Admin?      @relation("CashierOrders", fields: [cashierId], references: [id])
  orderType   String      // "print" | "atk" | "mixed"
  status      String      // "menunggu_pembayaran" | "diterima" | "diproses" | "siap_diambil" | "selesai" | "dibatalkan"
  totalAmount Float
  pickupNote  String      @default("")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  payments    Payment[]
  notes       Note[]
  stamps      Stamp[]
}

model OrderItem {
  id         Int          @id @default(autoincrement())
  orderId    Int
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType   String       // "print_doc" | "fotokopi" | "pas_foto" | "undangan" | "atk"
  productId  Int?
  product    Product?     @relation(fields: [productId], references: [id])
  fileUrl    String?
  specJson   Json         @default("{}") // JSON object for specs like { pages: 5, color: "bw", size: "A4" }
  qty        Int
  unitPrice  Float
  subtotal   Float
  addons     OrderAddon[]
}

model OrderAddon {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonType   String    // "jilid" | "laminating"
  price       Float
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String      @default("")
  imageUrl    String?
  price       Float
  stockQty    Int
  category    String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Payment {
  id                 Int       @id @default(autoincrement())
  orderId            Int
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod      String    // "qris" | "cash" | "manual"
  paymentGatewayRef  String?
  qrString           String?
  amount             Float
  status             String    // "pending" | "success" | "failed" | "expired"
  verifiedById       Int?
  verifiedBy         Admin?    @relation("VerifiedPayments", fields: [verifiedById], references: [id])
  paidAt             DateTime?
  webhookPayload     Json?
  createdAt          DateTime  @default(now())
}

model InventoryItem {
  id           Int            @id @default(autoincrement())
  itemName     String
  unit         String         // "rim" | "botol" | "pack" etc
  currentQty   Int
  minThreshold Int
  logs         InventoryLog[]
}

model InventoryLog {
  id              Int           @id @default(autoincrement())
  inventoryItemId Int
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  changeQty       Int           // negative for usage, positive for restock
  reason          String
  createdAt       DateTime      @default(now())
}

model Note {
  id        Int       @id @default(autoincrement())
  orderId   Int
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pdfUrl    String    @default("")
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model Stamp {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId    Int
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stampCount Int      @default(1)
  redeemed   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Admin {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  passwordHash     String
  role             String    // "owner" | "staff"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cashierOrders    Order[]   @relation("CashierOrders")
  verifiedPayments Payment[] @relation("VerifiedPayments")
}

model TaxSettings {
  id            Int      @id @default(autoincrement())
  taxType       String   // "ppn" | "pph"
  ratePercent   Float
  effectiveFrom DateTime
  isActive      Boolean  @default(true)
}

model TaxReport {
  id           Int      @id @default(autoincrement())
  periodType   String   // "harian" | "mingguan" | "bulanan" | "tahunan"
  periodValue  String   // e.g., "2026-07"
  totalRevenue Float
  ppnAmount    Float
  pphAmount    Float
  generatedAt  DateTime @default(now())
  fileUrl      String   @default("")
}
